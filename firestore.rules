rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate / Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isGuru() {
      return isSignedIn() && getUserData().role == 'guru';
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role == 'guru' || getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    // Users (Employees: Admin, Guru, Staff)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && uid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Students
    match /students/{nis} {
      allow read: if isStaff() || (request.headers.get('x-student-auth', '') == nis); // Simple header check for student read-only access to their own data
      allow list: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // Attendance
    match /attendance/{id} {
      allow read: if isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn(); // Karyawan individual check or Guru for students
      allow update, delete: if isAdmin();
    }

    // Exams
    match /exams/{id} {
      allow read: if isSignedIn() || true; // Students need to read exams
      allow list: if isSignedIn() || true;
      allow write: if isAdmin() || isGuru();
    }

    // Questions
    match /exams/{examId}/questions/{id} {
      allow read: if isSignedIn() || true;
      allow write: if isAdmin() || isGuru();
    }

    // Test Results
    match /test_results/{id} {
      allow list: if isStaff();
      allow read: if isStaff();
      allow create: if true; // Students submit results
      allow update, delete: if isAdmin();
    }
  }
}
